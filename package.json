{
  "name": "tailkit-starter-kit-laravel-inertia-vue",
  "private": true,
  "version": "5.0.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "update": "npm update --save && composer update && composer bump"
  },
  "prettier": {
    "tailwindStylesheet": "./resources/css/tailkit.css",
    "plugins": [
      "prettier-plugin-blade",
      "prettier-plugin-tailwindcss"
    ],
    "overrides": [
      {
        "files": [
          "*.blade.php"
        ],
        "options": {
          "parser": "blade",
          "htmlWhitespaceSensitivity": "ignore",
          "bladeKeepHeadAndBodyAtRoot": false
        }
      }
    ]
  },
  "devDependencies": {
    "@headlessui/vue": "^1.7.23",
    "@inertiajs/vite": "^3.0.0",
    "@inertiajs/vue3": "^3.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "laravel-vite-plugin": "^3.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-blade": "^3.1.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.17",
    "vite": "^8.0.3",
    "vue": "^3.5.25"
  }
}
